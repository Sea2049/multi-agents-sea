# 复制为 .env 后按需填写；不要将含真实密钥的 .env 提交到仓库。

# ─── 后端（server / Electron 启动的内嵌服务）────────────────────────────
# 监听端口（默认 3701；仅当直接运行 server 或需固定端口时设置）
# APP_PORT=3701

# SQLite 数据库路径（默认：进程 cwd 下 agency-agents.db）
# APP_DB_PATH=./agency-agents.db

# ─── Electron 开发 ───────────────────────────────────────────────────────
# 前端开发服务器地址（默认 http://127.0.0.1:5173）
# VITE_DEV_SERVER_URL=http://127.0.0.1:5173

# 设为 1 可在开发包下关闭 DevTools
# ELECTRON_DISABLE_DEVTOOLS=0

# ─── Provider（可选：也可仅在应用内通过 UI + 安全存储配置）──────────────
# PROVIDER_OPENAI_KEY=
# PROVIDER_ANTHROPIC_KEY=
# PROVIDER_MINIMAX_KEY=
# PROVIDER_MINIMAX_URL=
# DashScope 作为运行时自动备用模型（OpenAI-compatible）
# PROVIDER_DASHSCOPE_KEY=
# PROVIDER_DASHSCOPE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# PROVIDER_DASHSCOPE_MODEL=qwen-max
# PROVIDER_OLLAMA_URL=
