# 复制为 .env 后按需填写；不要将含真实密钥的 .env 提交到仓库。

# ─── 后端（server / Electron 启动的内嵌服务）────────────────────────────
# 监听端口（默认 3701；仅当直接运行 server 或需固定端口时设置）
# APP_PORT=3701

# SQLite 数据库路径（未设置时使用应用默认本地数据库路径）
# APP_DB_PATH=./agent-sea.db

# ─── Skills 市场（外部来源）───────────────────────────────────────────────
# 启用的市场 provider，逗号分隔（默认 clawhub）
# SEA_MARKET_PROVIDERS=clawhub

# ClawHub API 基础地址
# SEA_MARKET_CLAWHUB_BASE_URL=https://clawhub.ai

# 外部市场请求超时（毫秒）
# SEA_MARKET_HTTP_TIMEOUT_MS=20000

# 市场搜索单次最大返回数
# SEA_MARKET_RESULT_LIMIT=30

# 外部市场 429/5xx 重试次数（指数退避）
# SEA_MARKET_RETRY_MAX_ATTEMPTS=3

# 外部市场重试基准退避时间（毫秒）
# SEA_MARKET_RETRY_BASE_DELAY_MS=500

# 市场搜索结果本地缓存 TTL（毫秒）
# SEA_MARKET_SEARCH_CACHE_TTL_MS=300000

# 市场 bundle 本地缓存 TTL（毫秒）
# SEA_MARKET_BUNDLE_CACHE_TTL_MS=1800000

# 市场搜索缓存上限（LRU）
# SEA_MARKET_SEARCH_CACHE_MAX_ENTRIES=80

# 市场 bundle 缓存上限（LRU）
# SEA_MARKET_BUNDLE_CACHE_MAX_ENTRIES=40

# ─── Electron 开发 ───────────────────────────────────────────────────────
# 前端开发服务器地址（默认 http://127.0.0.1:5173）
# VITE_DEV_SERVER_URL=http://127.0.0.1:5173

# 设为 1 可在开发包下关闭 DevTools
# ELECTRON_DISABLE_DEVTOOLS=0

# ─── Provider（可选：也可仅在应用内通过 UI + 安全存储配置）──────────────
# PROVIDER_OPENAI_KEY=
# PROVIDER_ANTHROPIC_KEY=
# PROVIDER_MINIMAX_KEY=
# PROVIDER_MINIMAX_URL=
# DashScope 作为运行时自动备用模型（OpenAI-compatible）
# PROVIDER_DASHSCOPE_KEY=
# PROVIDER_DASHSCOPE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# PROVIDER_DASHSCOPE_MODEL=qwen-max
# PROVIDER_OLLAMA_URL=
